<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- ============================================================== -->
	<!-- GTI Weapon Wear  weapon repair                                 -->
	<!-- A single bill at the Machining table repairs any damaged weapon. -->
	<!-- The weapon is a count:1 ingredient that is NOT consumed         -->
	<!-- (repaired in place; quality/material preserved). Materials are   -->
	<!-- NOT listed here: WorkGiver_RepairWeapon computes them from the   -->
	<!-- weapon's own original cost (a fraction, scaled by damage,        -->
	<!-- components excluded) and hauls them dynamically. The incremental -->
	<!-- repair + proportional consumption happen in JobDriver_RepairWeapon. -->
	<!--                                                                 -->
	<!-- workerClass is the marker WorkGiver_RepairWeapon / the Harmony   -->
	<!-- safeguard use to recognise repair bills (and an atomic fallback).-->
	<!-- Default HP filter 0~99% so only damaged weapons are picked.      -->
	<!-- ============================================================== -->

	<RecipeDef>
		<defName>GTI_RepairWeapon</defName>
		<label>repair weapon</label>
		<description>Repair a damaged weapon at the machining table. Uses a fraction (~25%) of the weapon's own original materials, scaled by how damaged it is; components are never needed. Quality and material are preserved.</description>
		<jobString>Repairing weapon.</jobString>
		<workerClass>GTI_WeaponWear.RecipeWorker_RepairWeapon</workerClass>
		<effectWorking>Smith</effectWorking>
		<soundWorking>Recipe_Machining</soundWorking>
		<workAmount>800</workAmount>
		<workSkill>Crafting</workSkill>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>Weapons</li>
					</categories>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<categories>
				<li>Weapons</li>
			</categories>
			<allowedHitPointsPercents>0~0.99</allowedHitPointsPercents>
		</fixedIngredientFilter>
		<recipeUsers>
			<li>TableMachining</li>
		</recipeUsers>
	</RecipeDef>

</Defs>
