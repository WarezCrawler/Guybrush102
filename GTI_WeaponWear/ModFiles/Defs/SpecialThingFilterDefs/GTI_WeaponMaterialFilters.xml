<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- ============================================================== -->
	<!-- Material-based weapon filters used to route weapons to the      -->
	<!-- correct repair recipe. Each filter MATCHES the weapons a given  -->
	<!-- recipe should NOT accept; the recipe then disallows it.         -->
	<!--   wood recipe  disallows GTI_WeaponNotWood   (keeps wood)        -->
	<!--   steel recipe disallows GTI_WeaponNotMetal  (keeps metal)       -->
	<!-- Stone weapons match both, so they end up in neither recipe.     -->
	<!-- configurable=false: internal routing only, no UI clutter.       -->
	<!-- ============================================================== -->

	<SpecialThingFilterDef>
		<defName>GTI_WeaponNotWood</defName>
		<label>non-wooden weapons</label>
		<description>Weapons that are not made of wood.</description>
		<parentCategory>Weapons</parentCategory>
		<allowedByDefault>true</allowedByDefault>
		<configurable>false</configurable>
		<saveKey>gtiWeaponNotWood</saveKey>
		<workerClass>GTI_WeaponWear.SpecialThingFilterWorker_WeaponNotWood</workerClass>
	</SpecialThingFilterDef>

	<SpecialThingFilterDef>
		<defName>GTI_WeaponNotMetal</defName>
		<label>non-metal weapons</label>
		<description>Weapons that are not made of metal.</description>
		<parentCategory>Weapons</parentCategory>
		<allowedByDefault>true</allowedByDefault>
		<configurable>false</configurable>
		<saveKey>gtiWeaponNotMetal</saveKey>
		<workerClass>GTI_WeaponWear.SpecialThingFilterWorker_WeaponNotMetal</workerClass>
	</SpecialThingFilterDef>

</Defs>
