<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- Stands in for DoBillsMachiningTable (workType Smithing, priority 75) at a -->
	<!-- higher priority, so repair bills become our incremental GTI_RepairWeapon  -->
	<!-- job. Normal crafting bills are passed through unchanged by the worker.     -->
	<WorkGiverDef>
		<defName>GTI_RepairWeaponMachining</defName>
		<label>repair weapons at machining table</label>
		<giverClass>GTI_WeaponWear.WorkGiver_RepairWeapon</giverClass>
		<workType>Smithing</workType>
		<priorityInType>80</priorityInType>
		<fixedBillGiverDefs>
			<li>TableMachining</li>
		</fixedBillGiverDefs>
		<verb>repair</verb>
		<gerund>repairing</gerund>
		<requiredCapacities>
			<li>Manipulation</li>
		</requiredCapacities>
		<prioritizeSustains>true</prioritizeSustains>
	</WorkGiverDef>

</Defs>
