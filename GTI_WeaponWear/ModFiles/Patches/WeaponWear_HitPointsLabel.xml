<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- ============================================================== -->
	<!-- GTI Weapon Wear  step 1 scaffolding                            -->
	<!-- Adds our StatPart to the vanilla MaxHitPoints stat. The vanilla -->
	<!-- def has no <parts> node, so we add the whole node here. The C#  -->
	<!-- StatPart (GTI_WeaponWear.StatPart_WeaponWearLabel) decides what  -->
	<!-- text to show and only contributes a line for weapons.           -->
	<!-- ============================================================== -->
	<Operation Class="PatchOperationAdd">
		<xpath>/Defs/StatDef[defName="MaxHitPoints"]</xpath>
		<value>
			<parts>
				<li Class="GTI_WeaponWear.StatPart_WeaponWearLabel" />
			</parts>
		</value>
	</Operation>

</Patch>
